# ============================================================
# PMPath — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PMPath
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# MongoDB Atlas: Get from https://cloud.mongodb.com
# Leave empty to use JSON file fallback (works out of the box)
MONGODB_URI=
MONGODB_DB_NAME=pmpath

# ── Auth (NextAuth v4) ────────────────────────────────────────
# Generate with: openssl rand -base64 32 (v4 also accepts NEXTAUTH_SECRET)
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Google OAuth (optional)
# From https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional)
# From https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Admin Invitation Codes ───────────────────────────────────────
# Supply one-time invite tokens for sensitive roles
ADMIN_SIGNUP_CODE=
SUPERADMIN_SIGNUP_CODE=

# ── Payments (Stripe) ─────────────────────────────────────────
# From https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Stripe Price IDs
STRIPE_PRICE_MONTHLY=price_
STRIPE_PRICE_ANNUAL=price_

# ── Email (Resend) ────────────────────────────────────────────
# From https://resend.com/api-keys
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@pmpath.app
RESEND_FROM_NAME=PMPath

# ── File Storage (Vercel Blob) ────────────────────────────────
# From https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=

# ── Analytics (optional) ─────────────────────────────────────
# Vercel Analytics — enabled automatically on Vercel
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ── Feature Flags ────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_TTS=true
NEXT_PUBLIC_ENABLE_STRIPE=false
NEXT_PUBLIC_ENABLE_OAUTH=false
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ── Rate Limiting ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
