{
  "name": "pmpath-app",
  "version": "1.0.0",
  "description": "PMPath — Project Management Transition App. Structured learning paths, mentorship, events, and community for aspiring PMs.",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed.ts --reset",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate 2>/dev/null || true"
  },
  "dependencies": {
    "next": "15.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",

    "next-auth": "5.0.0-beta.29",
    "bcryptjs": "3.0.2",
    "jsonwebtoken": "9.0.2",

    "mongodb": "6.16.0",
    "mongoose": "8.14.1",

    "zod": "3.24.3",

    "date-fns": "4.1.0",

    "lucide-react": "0.511.0",
    "clsx": "2.1.1",
    "tailwind-merge": "3.3.0",
    "class-variance-authority": "0.7.1",

    "framer-motion": "12.9.4",

    "@radix-ui/react-accordion": "1.2.11",
    "@radix-ui/react-avatar": "1.1.7",
    "@radix-ui/react-checkbox": "1.1.5",
    "@radix-ui/react-dialog": "1.1.14",
    "@radix-ui/react-dropdown-menu": "2.1.15",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-popover": "1.1.14",
    "@radix-ui/react-progress": "1.1.7",
    "@radix-ui/react-scroll-area": "1.2.9",
    "@radix-ui/react-select": "2.2.5",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slider": "1.3.5",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-switch": "1.2.5",
    "@radix-ui/react-tabs": "1.1.12",
    "@radix-ui/react-toast": "1.2.14",
    "@radix-ui/react-tooltip": "1.2.7",

    "react-hot-toast": "2.5.2",
    "sonner": "2.5.3",

    "recharts": "2.15.3",

    "zustand": "5.0.5",
    "swr": "2.3.3",
    "jotai": "2.12.3",

    "axios": "1.9.0",

    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",

    "react-hook-form": "7.56.3",
    "@hookform/resolvers": "4.1.3",

    "@tiptap/react": "2.11.7",
    "@tiptap/starter-kit": "2.11.7",
    "@tiptap/extension-placeholder": "2.11.7",

    "stripe": "18.1.0",
    "@stripe/stripe-js": "7.3.0",

    "resend": "4.5.1",
    "react-email": "3.0.7",

    "sharp": "0.34.5",
    "@vercel/blob": "1.0.0",

    "nanoid": "5.1.5",
    "slugify": "1.6.6",
    "marked": "15.0.12",
    "dompurify": "3.2.6",
    "copy-to-clipboard": "3.3.3",
    "react-intersection-observer": "9.16.0",
    "react-confetti": "6.4.0",
    "qrcode": "1.5.4",

    "next-pwa": "5.6.0"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "@types/node": "22.15.3",
    "@types/react": "19.1.3",
    "@types/react-dom": "19.1.3",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.9",
    "@types/qrcode": "1.5.5",
    "@types/dompurify": "3.0.5",

    "tailwindcss": "3.4.17",
    "postcss": "8.5.3",
    "autoprefixer": "10.4.21",
    "tailwind-scrollbar": "3.1.0",
    "@tailwindcss/typography": "0.5.16",
    "@tailwindcss/forms": "0.5.10",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "tailwindcss-animate": "1.0.7",

    "eslint": "9.25.1",
    "eslint-config-next": "15.3.1",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-import": "2.31.0",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.6.11",

    "vitest": "3.1.3",
    "@vitest/ui": "3.1.3",
    "@vitest/coverage-v8": "3.1.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "happy-dom": "17.5.4",

    "tsx": "4.19.3",
    "@next/bundle-analyzer": "15.3.1",
    "cross-env": "7.0.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    }
  }
}
