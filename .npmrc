# PMPath — pnpm configuration
# https://pnpm.io/npmrc

# Hoist all packages to support Next.js and tools that expect flat node_modules
shamefully-hoist=true
hoist=true

# Strict peer dependencies off for React 19 compatibility
strict-peer-dependencies=false
auto-install-peers=true

# Link workspace packages
link-workspace-packages=true

# Save exact versions
save-exact=false

# Registry
registry=https://registry.npmjs.org/

# Store location
# store-dir=~/.pnpm-store

# Lockfile settings
prefer-frozen-lockfile=false

# Node version requirement
# node-linker=hoisted
